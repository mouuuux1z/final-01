# Server
PORT=3000
NODE_ENV=development

# Database (SQLite for local dev — no PostgreSQL install required)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production / optional)
# DATABASE_URL="postgresql://mydoc:mydoc_secret@localhost:5432/mydoc_db?schema=public"

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

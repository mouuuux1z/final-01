generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  CLINIC
  DOCTOR
  PATIENT
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  DISABLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  REJECTED
}

enum AttendanceStatus {
  PENDING
  ATTENDED
  ABSENT
  LATE
}

enum DayOfWeek {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

enum SenderType {
  DOCTOR
  PATIENT
}

enum NotificationTargetType {
  ADMIN
  CLINIC
  DOCTOR
  PATIENT
  ALL
}

enum NotificationType {
  APPOINTMENT
  SYSTEM
  REMINDER
  CHAT
  COMPLAINT
  BOOKING
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintUserType {
  PATIENT
  DOCTOR
  CLINIC
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userType  UserType
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, userType])
  @@index([expiresAt])
  @@map("sessions")
}

model LoginAttempt {
  id        String    @id @default(uuid())
  email     String
  ipAddress String?
  success   Boolean   @default(false)
  userType  UserType?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("login_attempts")
}

model Admin {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([role])
  @@map("admins")
}

model Clinic {
  id             String       @id @default(uuid())
  name           String
  location       String
  city           String       @default("")
  specialization String       @default("")
  certificate    String?
  phone          String
  email          String       @unique
  password       String
  status         EntityStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  doctors Doctor[]

  @@index([email])
  @@index([status])
  @@map("clinics")
}

model Doctor {
  id             String       @id @default(uuid())
  serialNumber   String       @unique
  name           String
  email          String       @unique
  password       String
  specialization String
  phone          String
  city           String
  location       String?
  clinicInfo     String?
  description    String?
  image          String?
  certificate    String?
  rating         Float        @default(0)
  ratingCount    Int          @default(0)
  status         EntityStatus @default(PENDING)
  disableReason  String?
  isOnline       Boolean      @default(false)
  lastActive     DateTime?
  clinicId       String?      @map("clinic_id")
  createdAt      DateTime     @default(now())

  clinic                   Clinic?                    @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  appointments             Appointment[]
  schedules                DoctorSchedule[]
  availabilitySlots        DoctorAvailabilitySlot[]
  chatMessages             ChatMessage[]
  chatSettings             DoctorChatSettings?
  chatConversationSettings ChatConversationSettings[]
  ratings                  Rating[]

  @@index([email])
  @@index([status])
  @@index([clinicId])
  @@index([city])
  @@index([specialization])
  @@index([serialNumber])
  @@map("doctors")
}

model Patient {
  id                  String       @id @default(uuid())
  name                String
  email               String       @unique
  password            String
  phone               String
  status              EntityStatus @default(ACTIVE)
  attendancePoints    Int          @default(3)
  bookingBlockedUntil DateTime?
  createdAt           DateTime     @default(now())

  appointments             Appointment[]
  chatMessages             ChatMessage[]
  chatConversationSettings ChatConversationSettings[]
  ratings                  Rating[]

  @@index([email])
  @@index([status])
  @@index([phone])
  @@map("patients")
}

model Appointment {
  id               String            @id @default(uuid())
  doctorId         String            @map("doctor_id")
  patientId        String?           @map("patient_id")
  date             DateTime
  time             String
  status           AppointmentStatus @default(PENDING)
  notes            String?
  patientName      String?           @map("patient_name")
  patientPhone     String?           @map("patient_phone")
  attendanceStatus AttendanceStatus  @default(PENDING) @map("attendance_status")
  createdAt        DateTime          @default(now())

  doctor  Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([patientId])
  @@index([date])
  @@index([status])
  @@index([doctorId, date])
  @@map("appointments")
}

model DoctorSchedule {
  id        String    @id @default(uuid())
  doctorId  String    @map("doctor_id")
  dayOfWeek DayOfWeek @map("day_of_week")
  startTime String    @map("start_time")
  endTime   String    @map("end_time")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
  @@map("doctor_schedules")
}

model DoctorAvailabilitySlot {
  id       String   @id @default(uuid())
  doctorId String   @map("doctor_id")
  date     DateTime
  time     String
  isBooked Boolean  @default(false) @map("is_booked")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date, time])
  @@index([doctorId])
  @@index([date])
  @@index([doctorId, date])
  @@index([isBooked])
  @@map("doctor_availability_slots")
}

model ChatMessage {
  id         String     @id @default(uuid())
  doctorId   String     @map("doctor_id")
  patientId  String     @map("patient_id")
  senderType SenderType @map("sender_type")
  message    String
  fileUrl    String?    @map("file_url")
  readAt     DateTime?  @map("read_at")
  createdAt  DateTime   @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId, patientId])
  @@index([patientId])
  @@index([createdAt])
  @@map("chat_messages")
}

model DoctorChatSettings {
  id             String  @id @default(uuid())
  doctorId       String  @unique @map("doctor_id")
  repliesEnabled Boolean @default(false) @map("replies_enabled")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_chat_settings")
}

model ChatConversationSettings {
  id             String  @id @default(uuid())
  doctorId       String  @map("doctor_id")
  patientId      String  @map("patient_id")
  repliesEnabled Boolean @default(false) @map("replies_enabled")

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
  @@index([doctorId])
  @@index([patientId])
  @@map("chat_conversation_settings")
}

model Notification {
  id         String                 @id @default(uuid())
  targetType NotificationTargetType @map("target_type")
  targetId   String?                @map("target_id")
  title      String
  message    String
  type       NotificationType
  read       Boolean                @default(false)
  createdAt  DateTime               @default(now())

  @@index([targetType, targetId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model Complaint {
  id        String            @id @default(uuid())
  userType  ComplaintUserType @map("user_type")
  userId    String            @map("user_id")
  subject   String
  body      String
  status    ComplaintStatus   @default(OPEN)
  createdAt DateTime          @default(now())

  @@index([userType, userId])
  @@index([status])
  @@index([createdAt])
  @@map("complaints")
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  adminName String   @map("admin_name")
  details   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([adminName])
  @@map("activity_logs")
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_content")
}

model Rating {
  id        String   @id @default(uuid())
  doctorId  String   @map("doctor_id")
  patientId String   @map("patient_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
  @@index([doctorId])
  @@index([patientId])
  @@index([rating])
  @@map("ratings")
}
